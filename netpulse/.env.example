TZ=America/Sao_Paulo

# Porta do dashboard local
NETPULSE_PORT=8097

# Diretório persistente com SQLite e artefatos locais
NETPULSE_DATA_DIR=./data

# Frequência de coleta. 30s gera 2.880 amostras/dia e continua bem leve.
NETPULSE_POLL_INTERVAL_SECONDS=30

# Retenção dos logs brutos
NETPULSE_LOG_RETENTION_DAYS=30

# Tamanho máximo dos logs brutos em MB
NETPULSE_LOG_MAX_SIZE_MB=100

# Retenção dos dados agregados usados nos gráficos
NETPULSE_GRAPH_RETENTION_DAYS=365

# Hostname usado nas consultas DNS
NETPULSE_DNS_HOSTNAME=google.com

# Resolvedores usados para diferenciar falha DNS de falha de internet
NETPULSE_DNS_RESOLVERS=1.1.1.1,8.8.8.8

# Alvos TCP usados como prova de conectividade IP
NETPULSE_TCP_TARGETS=1.1.1.1:53,8.8.8.8:53

# Timeouts individuais por teste
NETPULSE_DNS_TIMEOUT_SECONDS=2
NETPULSE_TCP_TIMEOUT_SECONDS=2
