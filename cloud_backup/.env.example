# Example file only.
# Do not store real passwords, tokens or provider credentials in versioned files.

# Ports
CLOUD_BACKUP_WEB_PORT=8095
CLOUD_BACKUP_API_PORT=8096

# Persistent service data directory on the host.
# Example for your server layout:
# CLOUD_BACKUP_DATA_DIR=/mnt/m2/docker/cloud_backup
CLOUD_BACKUP_DATA_DIR=./data

# Time zone and naming
TZ=America/Sao_Paulo
CLOUD_BACKUP_HOSTNAME=homelab

# Source mounts exposed inside the containers
PRIMARY_SOURCE_PATH=/mnt/raid1
SECONDARY_SOURCE_PATH=/mnt/m2
PRIMARY_SOURCE_ROOT=/source/raid1
SECONDARY_SOURCE_ROOT=/source/m2
CLOUD_BACKUP_DATA_DIR=/source/m2/docker/cloud_backup

# Restic + rclone defaults used for the initial config bootstrap
RESTIC_REPOSITORY=rclone:gdrive:/backups/restic
RESTIC_PASSWORD=
BANDWIDTH_LIMIT=4M

# Notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
WEBHOOK_URL=
NOTIFY_ON_SUCCESS=true
NOTIFY_ON_FAILURE=true

# Optional safety integration with disk-health
# CLOUD_BACKUP_DISK_HEALTH_FILE=/health/disk-health.json
# CLOUD_BACKUP_DISK_HEALTH_BLOCKER_FILE=/health/backup.block

# Google Drive can be provided here for headless rclone bootstrap if desired.
# The UI/API can also persist rclone.conf directly in ./data/rclone/rclone.conf.
# RCLONE_CONFIG_GDRIVE_TYPE=drive
# RCLONE_CONFIG_GDRIVE_CLIENT_ID=
# RCLONE_CONFIG_GDRIVE_CLIENT_SECRET=
# RCLONE_CONFIG_GDRIVE_TOKEN={"access_token":"...","refresh_token":"..."}
